# Database — local dev uses docker-compose SQL Server (see docker-compose.yaml)
# Production/staging get DATABASE_URL from Key Vault via App Service references (see infra/bicep)
# To bootstrap local dev:
#   docker compose up -d sql
#   ./packages/db/scripts/init-dev-db.sh
#   cp .env.example packages/db/.env  (override as needed)
# trustServerCertificate should only be true in local dev with a self-signed cert.
DATABASE_URL="sqlserver://localhost:1433;database=cems_dev;user=SA;password=Your_strong_pw_123;trustServerCertificate=true;encrypt=true"

# Authentication
JWT_SECRET="replace-with-a-strong-secret-min-32-chars"
JWT_REFRESH_SECRET="replace-with-a-different-strong-secret"

# Azure Storage (Photos + PDFs)
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER_PHOTOS="audit-photos"
AZURE_STORAGE_CONTAINER_REPORTS="audit-reports"

# Redis (BullMQ job queue + caching)
REDIS_URL="redis://localhost:6379"

# Email (Resend)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@cems.starenergy.ca"

# Claude AI (LLM anomaly detection)
CLAUDE_API_KEY="sk-ant-..."

# Calculation Service
CALC_SERVICE_URL="http://localhost:8000"

# API
PORT=3001
NODE_ENV=development
API_BASE_URL="http://localhost:3001"

    "playwright": "playwright test",
    "playwright:install": "playwright install --with-deps chromium",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "eslint": "^10.4.0",
    "turbo": "2.9.6"
  }
}

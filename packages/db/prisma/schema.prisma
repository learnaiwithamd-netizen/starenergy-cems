// Prisma schema for Star Energy CEMS
// Database: Azure SQL (SQL Server) with Row-Level Security
// Migration: prisma migrate dev (dev) / prisma migrate deploy (CI/CD)

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}


{
  "name": "@cems/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -b",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed:test-users": "tsx scripts/seed-test-users.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@cems/types": "workspace:*",
    "@prisma/adapter-mssql": "7.8.0",
    "@prisma/client": "7.8.0",
    "argon2": "^0.41.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cems/config": "workspace:*",
    "@types/node": "^22.10.5",
    "dotenv": "^16.4.7",
    "prisma": "7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Turborepo
.turbo/

# TypeScript incremental build cache
*.tsbuildinfo

# tsc -b project-build output emitted next to source in workspace packages
# (no outDir override in package tsconfigs; apps' tsc -b triggers cross-package emit)
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Compiled Bicep ARM JSON output (generated by `bicep build`, never edit by hand)
infra/bicep/**/*.json

# Environment variables
.env
.env.local
.env.*.local
*.local
# packages/db/.env holds local dev DB credentials — never commit
packages/db/.env

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# Coverage
coverage/
*.lcov

# Prisma
prisma/migrations/dev.db

// rootDir is set to src now that workspace packages compile to JS (dist/).
// Previously, paths aliases pointed at TS source files which forced tsc to
// infer the workspace root as rootDir, breaking the expected output layout.
{
  "extends": "@cems/config/typescript/server.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"]
}
